---
/**
 * Resume Export modal for generating ATS-friendly PDF and Word documents.
 * Libraries are dynamically imported for optimal code-splitting.
 */
import { profile, activeSections } from "../data/profile";

// Serialize profile data for client-side generation
const exportData = JSON.stringify({
  fullName: profile.fullName,
  firstName: profile.firstName,
  lastName: profile.lastName,
  title: profile.title,
  subtitle: profile.subtitle,
  contact: profile.contact,
  socialLinks: profile.socialLinks,
  about: profile.about,
  technicalSkills: profile.technicalSkills,
  softSkills: profile.softSkills,
  education: profile.education,
  experience: profile.experience,
  publications: profile.publications,
  certifications: profile.certifications,
  projects: profile.projects,
  activeSections: activeSections
});

const icons: Record<string, string> = {
  x: `<path d="M18 6 6 18"/><path d="M6 6l12 12"/>`,
  "file-text": `<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8m8 4H8m8 4H8"/>`,
  "file-type": `<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M9 13v-1h6v1M11 18v-5m2 5v-5"/>`,
  loader: `<path d="M21 12a9 9 0 1 1-6.219-8.56"/>`
};
---

<div class="resume-modal" aria-hidden="true" data-resume-modal data-export={exportData}>
  <div class="modal-backdrop" data-modal-backdrop></div>
  <div class="modal-content">
    <header class="modal-header">
      <h2>Télécharger le CV</h2>
      <button class="modal-close" aria-label="Fermer" data-modal-close>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons.x}></svg>
      </button>
    </header>

    <div class="modal-body">
      <p class="modal-desc">Exportez le portfolio de {profile.fullName} au format de votre choix. Les deux formats sont optimisés pour les systèmes ATS (Applicant Tracking Systems).</p>
      
      <div class="format-cards">
        <button class="format-card" data-format="pdf">
          <div class="format-icon pdf">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons["file-text"]}></svg>
          </div>
          <div class="format-info">
            <span class="format-badge pdf">PDF</span>
            <h3>Document PDF</h3>
            <p>Idéal pour les candidatures en ligne et par email</p>
          </div>
        </button>

        <button class="format-card" data-format="docx">
          <div class="format-icon docx">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons["file-type"]}></svg>
          </div>
          <div class="format-info">
            <span class="format-badge docx">DOCX</span>
            <h3>Document Word</h3>
            <p>Idéal pour les modifications et systèmes ATS</p>
          </div>
        </button>
      </div>
    </div>

    <div class="modal-status" data-modal-status>
      <span class="status-text" data-status-text>Prêt à exporter</span>
    </div>
  </div>
</div>

<style>
  .resume-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: grid;
    place-items: center;
    padding: 20px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms ease;
  }

  .resume-modal.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(4, 9, 19, 0.75);
    backdrop-filter: blur(4px);
  }

  :global(html[data-theme="light"]) .modal-backdrop {
    background: rgba(0, 0, 0, 0.4);
  }

  .modal-content {
    position: relative;
    width: 100%;
    max-width: 540px;
    background: rgba(12, 18, 31, 0.98);
    border: 1px solid var(--border);
    border-radius: 20px;
    backdrop-filter: blur(20px);
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.5);
    transform: scale(0.9) translateY(20px);
    transition: transform 250ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  :global(html[data-theme="light"]) .modal-content {
    background: rgba(255, 255, 255, 0.98);
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.2);
  }

  .resume-modal.is-open .modal-content {
    transform: scale(1) translateY(0);
  }

  .modal-header {
    padding: 18px 20px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .modal-header h2 {
    margin: 0;
    font-size: 1.15rem;
  }

  .modal-close {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    border: none;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: background 180ms ease, color 180ms ease;
  }

  .modal-close:hover {
    background: rgba(255, 255, 255, 0.1);
    color: var(--text);
  }

  .modal-close svg {
    width: 20px;
    height: 20px;
  }

  .modal-body {
    padding: 20px;
  }

  .modal-desc {
    margin: 0 0 20px;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .format-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }

  .format-card {
    padding: 18px;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.04);
    cursor: pointer;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: border-color 200ms ease, background 200ms ease, transform 200ms ease;
  }

  :global(html[data-theme="light"]) .format-card {
    background: rgba(0, 0, 0, 0.03);
  }

  .format-card:hover {
    transform: translateY(-4px);
  }

  .format-card:hover.format-card[data-format="pdf"] {
    border-color: rgba(239, 68, 68, 0.5);
    background: rgba(239, 68, 68, 0.08);
  }

  .format-card:hover.format-card[data-format="docx"] {
    border-color: rgba(59, 130, 246, 0.5);
    background: rgba(59, 130, 246, 0.08);
  }

  .format-card.is-loading {
    pointer-events: none;
    opacity: 0.7;
  }

  .format-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: grid;
    place-items: center;
  }

  .format-icon.pdf {
    background: rgba(239, 68, 68, 0.15);
    color: #ef4444;
  }

  .format-icon.docx {
    background: rgba(59, 130, 246, 0.15);
    color: #3b82f6;
  }

  .format-icon svg {
    width: 24px;
    height: 24px;
  }

  .format-info {
    flex: 1;
  }

  .format-badge {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .format-badge.pdf {
    background: rgba(239, 68, 68, 0.2);
    color: #fca5a5;
  }

  .format-badge.docx {
    background: rgba(59, 130, 246, 0.2);
    color: #93c5fd;
  }

  .format-info h3 {
    margin: 0 0 4px;
    font-size: 1rem;
    color: var(--text);
  }

  .format-info p {
    margin: 0;
    font-size: 0.82rem;
    color: var(--muted);
  }

  .modal-status {
    padding: 14px 20px;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .status-text {
    font-size: 0.85rem;
    color: var(--muted);
  }

  .modal-status.is-loading .status-text::before {
    content: "";
    display: inline-block;
    width: 14px;
    height: 14px;
    border: 2px solid var(--border);
    border-top-color: var(--primary);
    border-radius: 50%;
    margin-right: 8px;
    animation: spin 0.8s linear infinite;
    vertical-align: middle;
  }

  .modal-status.is-success .status-text {
    color: var(--success);
  }

  .modal-status.is-error .status-text {
    color: var(--accent);
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @media (max-width: 600px) {
    .format-cards {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Resume Export functionality with dynamic library imports
  const modal = document.querySelector("[data-resume-modal]") as HTMLElement;
  
  if (modal) {
    const backdrop = modal.querySelector("[data-modal-backdrop]");
    const closeBtn = modal.querySelector("[data-modal-close]");
    const statusEl = modal.querySelector("[data-modal-status]") as HTMLElement;
    const statusText = modal.querySelector("[data-status-text]") as HTMLElement;
    const formatCards = modal.querySelectorAll("[data-format]");

    // Parse export data
    const data = JSON.parse(modal.dataset.export || "{}");

    // Helper to strip HTML
    const stripHtml = (text: string): string => {
      return text?.replace(/<[^>]*>/g, "").trim() || "";
    };

    // Open modal (triggered by custom event from Hero)
    document.addEventListener("open-resume-modal", () => {
      modal.classList.add("is-open");
      modal.setAttribute("aria-hidden", "false");
    });

    // Close modal
    const closeModal = () => {
      modal.classList.remove("is-open");
      modal.setAttribute("aria-hidden", "true");
      statusEl.className = "modal-status";
      statusText.textContent = "Prêt à exporter";
    };

    backdrop?.addEventListener("click", closeModal);
    closeBtn?.addEventListener("click", closeModal);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && modal.classList.contains("is-open")) {
        closeModal();
      }
    });

    // Set status
    const setStatus = (text: string, type: "loading" | "success" | "error" | "") => {
      statusEl.className = `modal-status ${type ? `is-${type}` : ""}`;
      statusText.textContent = text;
    };

    // Generate PDF
    const generatePdf = async () => {
      setStatus("Génération du PDF en cours...", "loading");
      
      try {
        // Dynamic import
        const { jsPDF } = await import("jspdf");
        const doc = new jsPDF({ unit: "mm", format: "a4" });
        
        const margin = 15;
        const pageWidth = 210;
        const contentWidth = pageWidth - margin * 2;
        let y = margin;

        // Helper for text wrapping
        const addWrappedText = (text: string, fontSize: number, lineHeight: number = 1.4): number => {
          doc.setFontSize(fontSize);
          const lines = doc.splitTextToSize(text, contentWidth);
          lines.forEach((line: string) => {
            if (y > 270) {
              doc.addPage();
              y = margin;
            }
            doc.text(line, margin, y);
            y += fontSize * 0.35 * lineHeight;
          });
          return y;
        };

        // Header - Name
        doc.setFont("helvetica", "bold");
        doc.setFontSize(22);
        doc.text(data.fullName, pageWidth / 2, y, { align: "center" });
        y += 8;

        // Title
        doc.setFont("helvetica", "normal");
        doc.setFontSize(12);
        doc.setTextColor(100);
        doc.text(data.title, pageWidth / 2, y, { align: "center" });
        y += 8;

        // Contact line
        doc.setFontSize(10);
        const contactParts = [];
        if (data.contact?.email) contactParts.push(data.contact.email);
        if (data.contact?.phone) contactParts.push(data.contact.phone);
        if (data.contact?.location) contactParts.push(data.contact.location);
        if (contactParts.length > 0) {
          doc.text(contactParts.join(" | "), pageWidth / 2, y, { align: "center" });
          y += 6;
        }

        // Social links
        const links = data.socialLinks?.filter((s: any) => s.label !== "Email")
          .map((s: any) => s.label).join(" | ");
        if (links) {
          doc.text(links, pageWidth / 2, y, { align: "center" });
          y += 10;
        }

        doc.setTextColor(0);

        // Section helper
        const addSection = (title: string) => {
          y += 6;
          if (y > 260) { doc.addPage(); y = margin; }
          doc.setFont("helvetica", "bold");
          doc.setFontSize(12);
          doc.text(title.toUpperCase(), margin, y);
          y += 2;
          doc.setDrawColor(59, 130, 246);
          doc.setLineWidth(0.5);
          doc.line(margin, y, pageWidth - margin, y);
          y += 6;
          doc.setFont("helvetica", "normal");
        };

        // Professional Summary
        if (data.about?.length > 0) {
          addSection("Résumé Professionnel");
          const summary = data.about.map((b: any) => stripHtml(b.text)).join(" ");
          addWrappedText(summary, 10);
        }

        // Experience
        if (data.experience?.length > 0) {
          addSection("Expérience Professionnelle");
          data.experience.forEach((exp: any) => {
            doc.setFont("helvetica", "bold");
            addWrappedText(`${exp.role}`, 11);
            doc.setFont("helvetica", "italic");
            addWrappedText(`${exp.organization} | ${exp.period}`, 10);
            doc.setFont("helvetica", "normal");
            if (exp.description) {
              addWrappedText(`• ${stripHtml(exp.description)}`, 10);
            }
            y += 3;
          });
        }

        // Education
        if (data.education?.length > 0) {
          addSection("Formation");
          data.education.forEach((edu: any) => {
            doc.setFont("helvetica", "bold");
            addWrappedText(`${edu.degree} - ${edu.field}`, 11);
            doc.setFont("helvetica", "italic");
            addWrappedText(`${edu.institution} | ${edu.period}`, 10);
            doc.setFont("helvetica", "normal");
            if (edu.description) {
              addWrappedText(stripHtml(edu.description), 10);
            }
            y += 3;
          });
        }

        // Technical Skills
        if (data.technicalSkills?.length > 0) {
          addSection("Compétences Techniques");
          data.technicalSkills.forEach((cat: any) => {
            addWrappedText(`${cat.category}: ${cat.items.join(", ")}`, 10);
          });
        }

        // Soft Skills
        if (data.softSkills?.length > 0) {
          addSection("Compétences Transversales");
          const softList = data.softSkills.map((s: any) => s.name).join(", ");
          addWrappedText(softList, 10);
        }

        // Projects
        if (data.projects?.length > 0) {
          addSection("Projets");
          data.projects.forEach((proj: any) => {
            doc.setFont("helvetica", "bold");
            addWrappedText(proj.title, 11);
            doc.setFont("helvetica", "normal");
            addWrappedText(`• ${stripHtml(proj.description)}`, 10);
            addWrappedText(`Technologies: ${proj.tags.join(", ")}`, 9);
            y += 2;
          });
        }

        // Publications
        if (data.publications?.length > 0) {
          addSection("Publications");
          data.publications.forEach((pub: any) => {
            doc.setFont("helvetica", "bold");
            addWrappedText(pub.title, 10);
            doc.setFont("helvetica", "italic");
            addWrappedText(`${pub.venue} (${pub.year})`, 9);
            doc.setFont("helvetica", "normal");
            y += 2;
          });
        }

        // Save
        const fileName = `${data.firstName}_${data.lastName}_Resume.pdf`;
        doc.save(fileName);
        setStatus(`${fileName} téléchargé avec succès !`, "success");

      } catch (error) {
        console.error("PDF generation error:", error);
        setStatus("Erreur lors de la génération du PDF", "error");
      }
    };

    // Generate DOCX
    const generateDocx = async () => {
      setStatus("Génération du document Word en cours...", "loading");
      
      try {
        // Dynamic imports
        const docxModule = await import("docx");
        const { Document, Paragraph, TextRun, HeadingLevel, AlignmentType, Packer } = docxModule;
        const { saveAs } = await import("file-saver");

        const children: any[] = [];

        // Helper for section heading
        const addHeading = (text: string) => {
          children.push(new Paragraph({
            text: text.toUpperCase(),
            heading: HeadingLevel.HEADING_2,
            spacing: { before: 300, after: 100 },
            border: { bottom: { color: "3B82F6", size: 6, style: "single" as any } }
          }));
        };

        // Name
        children.push(new Paragraph({
          children: [new TextRun({ text: data.fullName, bold: true, size: 36 })],
          alignment: AlignmentType.CENTER,
          spacing: { after: 100 }
        }));

        // Title
        children.push(new Paragraph({
          children: [new TextRun({ text: data.title, size: 24, color: "666666" })],
          alignment: AlignmentType.CENTER,
          spacing: { after: 100 }
        }));

        // Contact
        const contactParts = [];
        if (data.contact?.email) contactParts.push(data.contact.email);
        if (data.contact?.phone) contactParts.push(data.contact.phone);
        if (data.contact?.location) contactParts.push(data.contact.location);
        if (contactParts.length > 0) {
          children.push(new Paragraph({
            children: [new TextRun({ text: contactParts.join(" | "), size: 20 })],
            alignment: AlignmentType.CENTER,
            spacing: { after: 200 }
          }));
        }

        // Professional Summary
        if (data.about?.length > 0) {
          addHeading("Résumé Professionnel");
          const summary = data.about.map((b: any) => stripHtml(b.text)).join(" ");
          children.push(new Paragraph({ text: summary, spacing: { after: 100 } }));
        }

        // Experience
        if (data.experience?.length > 0) {
          addHeading("Expérience Professionnelle");
          data.experience.forEach((exp: any) => {
            children.push(new Paragraph({
              children: [new TextRun({ text: exp.role, bold: true })],
              spacing: { before: 100 }
            }));
            children.push(new Paragraph({
              children: [
                new TextRun({ text: exp.organization, italics: true }),
                new TextRun({ text: ` | ${exp.period}` })
              ]
            }));
            if (exp.description) {
              children.push(new Paragraph({
                text: `• ${stripHtml(exp.description)}`,
                spacing: { after: 100 }
              }));
            }
          });
        }

        // Education
        if (data.education?.length > 0) {
          addHeading("Formation");
          data.education.forEach((edu: any) => {
            children.push(new Paragraph({
              children: [new TextRun({ text: `${edu.degree} - ${edu.field}`, bold: true })],
              spacing: { before: 100 }
            }));
            children.push(new Paragraph({
              children: [
                new TextRun({ text: edu.institution, italics: true }),
                new TextRun({ text: ` | ${edu.period}` })
              ]
            }));
            if (edu.description) {
              children.push(new Paragraph({
                text: stripHtml(edu.description),
                spacing: { after: 100 }
              }));
            }
          });
        }

        // Skills
        if (data.technicalSkills?.length > 0) {
          addHeading("Compétences Techniques");
          data.technicalSkills.forEach((cat: any) => {
            children.push(new Paragraph({
              children: [
                new TextRun({ text: `${cat.category}: `, bold: true }),
                new TextRun({ text: cat.items.join(", ") })
              ],
              spacing: { after: 50 }
            }));
          });
        }

        if (data.softSkills?.length > 0) {
          addHeading("Compétences Transversales");
          children.push(new Paragraph({
            text: data.softSkills.map((s: any) => s.name).join(", "),
            spacing: { after: 100 }
          }));
        }

        // Projects
        if (data.projects?.length > 0) {
          addHeading("Projets");
          data.projects.forEach((proj: any) => {
            children.push(new Paragraph({
              children: [new TextRun({ text: proj.title, bold: true })],
              spacing: { before: 100 }
            }));
            children.push(new Paragraph({
              text: `• ${stripHtml(proj.description)}`,
            }));
            children.push(new Paragraph({
              children: [
                new TextRun({ text: "Technologies: ", italics: true }),
                new TextRun({ text: proj.tags.join(", ") })
              ],
              spacing: { after: 100 }
            }));
          });
        }

        // Publications
        if (data.publications?.length > 0) {
          addHeading("Publications");
          data.publications.forEach((pub: any) => {
            children.push(new Paragraph({
              children: [new TextRun({ text: pub.title, bold: true })],
              spacing: { before: 100 }
            }));
            children.push(new Paragraph({
              children: [
                new TextRun({ text: pub.venue, italics: true }),
                new TextRun({ text: ` (${pub.year})` })
              ],
              spacing: { after: 100 }
            }));
          });
        }

        // Create document
        const doc = new Document({
          sections: [{
            properties: {},
            children: children
          }]
        });

        // Generate and save
        const blob = await Packer.toBlob(doc);
        const fileName = `${data.firstName}_${data.lastName}_Resume.docx`;
        saveAs(blob, fileName);
        setStatus(`${fileName} téléchargé avec succès !`, "success");

      } catch (error) {
        console.error("DOCX generation error:", error);
        setStatus("Erreur lors de la génération du document Word", "error");
      }
    };

    // Format card click handlers
    formatCards.forEach((card) => {
      card.addEventListener("click", async () => {
        const format = (card as HTMLElement).dataset.format;
        card.classList.add("is-loading");
        
        try {
          if (format === "pdf") {
            await generatePdf();
          } else if (format === "docx") {
            await generateDocx();
          }
        } finally {
          card.classList.remove("is-loading");
        }
      });
    });
  }
</script>
