---
/**
 * Footer showing brand, dynamic quick navigation and social links.
 */
import type { NavItem, ProfileData } from "../data/profile";

type Props = {
  navItems: NavItem[];
  profile: ProfileData;
};

const { navItems, profile } = Astro.props;

const icons: Record<string, string> = {
  github: `<path d="M15 22v-4a4 4 0 0 0-1-2.8c3.2-.35 6.5-1.6 6.5-7.2A5.6 5.6 0 0 0 19 4.3 5.2 5.2 0 0 0 18.9 1s-1.2-.4-3.9 1.5a13.4 13.4 0 0 0-7 0C5.3.6 4.1 1 4.1 1A5.2 5.2 0 0 0 4 4.3a5.6 5.6 0 0 0-1.5 3.7c0 5.6 3.3 6.8 6.5 7.2A4 4 0 0 0 8 18v4"/><path d="M9 18c-4.5 2-5-2-7-2"/>`,
  mail: `<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-10 6L2 7"/>`,
  link: `<path d="M10 13a5 5 0 0 0 7.07 0l3.54-3.54a5 5 0 1 0-7.07-7.07L11 4"/><path d="M14 11a5 5 0 0 0-7.07 0L3.39 14.54a5 5 0 1 0 7.07 7.07L13 20"/>`
};
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-col brand-col">
      <div class="footer-brand">
        <span class="footer-logo" aria-hidden="true">//</span>
        <div>
          <p class="footer-name">{profile.fullName}</p>
          <p class="footer-desc">Portfolio orienté projets, progression continue et impact concret.</p>
        </div>
      </div>
    </div>

    <div class="footer-col">
      <p class="footer-title">Navigation Rapide</p>
      <nav aria-label="Navigation pied de page" class="footer-links">
        {navItems.map((item) => (
          <a href={`#${item.id}`}>{item.label}</a>
        ))}
      </nav>
    </div>

    <div class="footer-col">
      <p class="footer-title">Connexion</p>
      <div class="social-list">
        {profile.socialLinks.map((link) => (
          <a href={link.href} target="_blank" rel="noreferrer" class="social-link">
            <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[link.icon] ?? icons.link}></svg>
            <span>{link.label}</span>
          </a>
        ))}
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <span>© {new Date().getFullYear()} {profile.fullName}</span>
      <span>Built with Astro, deployed on Vercel</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 80px;
    background: rgba(9, 14, 26, 0.72);
    border-top: 1px solid var(--border);
    backdrop-filter: blur(16px);
  }

  .footer-grid {
    padding: 48px 0 30px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 28px;
  }

  .footer-brand {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }

  .footer-logo {
    width: 42px;
    height: 42px;
    display: grid;
    place-items: center;
    border-radius: 10px;
    background: var(--gradient-a);
    color: #04141c;
    font-family: var(--font-mono);
    font-weight: 800;
  }

  .footer-name {
    margin: 0;
    font-weight: 700;
  }

  .footer-desc {
    margin: 8px 0 0;
    color: var(--muted);
    max-width: 33ch;
  }

  .footer-title {
    margin: 0 0 12px;
    font-size: 0.92rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #d3defd;
  }

  .footer-links {
    display: grid;
    gap: 7px;
  }

  .footer-links a,
  .social-link {
    color: var(--muted);
    transition: color 220ms ease, transform 220ms ease;
  }

  .footer-links a:hover,
  .social-link:hover {
    color: #e7f6ff;
    transform: translateX(4px);
  }

  .social-list {
    display: grid;
    gap: 8px;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .social-link svg {
    width: 16px;
    height: 16px;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer-bottom-inner {
    padding: 16px 0;
    display: flex;
    justify-content: space-between;
    gap: 10px;
    color: var(--muted);
    font-size: 0.9rem;
  }

  @media (max-width: 960px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 22px;
      padding-top: 36px;
    }

    .footer-bottom-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
