---
/**
 * About section rendered as numbered highlight cards.
 */
import type { ProfileData } from "../data/profile";

type Props = { profile: ProfileData };
const { profile } = Astro.props;
---

<section id="about" class="section">
  <div class="container">
    <p class="section-kicker reveal">A propos</p>
    <h2 class="section-title reveal" data-delay="30">Presentation personnelle</h2>

    <div class="about-grid">
      {profile.about.map((block, index) => (
        <article class="glass-card about-card reveal" data-delay={String(70 + index * 55)}>
          <span class="about-number">{String(index + 1).padStart(2, "0")}</span>
          <h3>{block.title}</h3>
          <p>{block.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .about-grid {
    margin-top: 20px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .about-card {
    padding: 20px;
    border-left: 3px solid transparent;
    border-image: var(--gradient-a) 1;
  }

  .about-number {
    display: inline-block;
    font-family: var(--font-mono);
    color: var(--muted);
    margin-bottom: 8px;
  }

  .about-card h3 {
    margin: 0 0 8px;
    font-size: 1.05rem;
  }

  .about-card p {
    margin: 0;
    color: var(--muted);
  }

  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
