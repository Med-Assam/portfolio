---
/**
 * AI Assistant chatbot with floating toggle button and knowledge base built from profile data.
 * Uses client-side keyword matching for conversational responses without external APIs.
 */
import { profile, activeSections } from "../data/profile";

// Build quick actions based on active sections
const quickActions = [
  { label: `Qui est ${profile.firstName} ?`, key: "about" },
  activeSections.skills && { label: "Compétences", key: "skills" },
  activeSections.education && { label: "Éducation", key: "education" },
  activeSections.experience && { label: "Expérience", key: "experience" },
  activeSections.publications && { label: "Publications", key: "publications" },
  activeSections.projects && { label: "Projets", key: "projects" },
  activeSections.contact && { label: "Contact", key: "contact" }
].filter(Boolean) as Array<{ label: string; key: string }>;

// Serialize profile data for client-side access
const profileJson = JSON.stringify({
  firstName: profile.firstName,
  lastName: profile.lastName,
  fullName: profile.fullName,
  title: profile.title,
  subtitle: profile.subtitle,
  availabilityBadge: profile.availabilityBadge,
  contact: profile.contact,
  stats: profile.stats,
  about: profile.about,
  technicalSkills: profile.technicalSkills,
  softSkills: profile.softSkills,
  education: profile.education,
  experience: profile.experience,
  publications: profile.publications,
  certifications: profile.certifications,
  projects: profile.projects,
  socialLinks: profile.socialLinks,
  academicLinks: profile.academicLinks
});

const icons: Record<string, string> = {
  bot: `<path d="M12 8V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v2"/><rect width="20" height="12" x="2" y="8" rx="2"/><path d="M6 15h.01M10 15h.01M14 15h.01M18 15h.01"/>`,
  x: `<path d="M18 6 6 18"/><path d="M6 6l12 12"/>`,
  send: `<path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/>`
};
---

<div class="ai-assistant" data-ai-assistant data-profile={profileJson} data-quick-actions={JSON.stringify(quickActions)}>
  <!-- Toggle Button -->
  <button class="ai-toggle" aria-label="Ouvrir l'assistant IA" data-ai-toggle>
    <span class="pulse-ring"></span>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons.bot}></svg>
  </button>

  <!-- Chat Panel -->
  <div class="ai-panel" aria-hidden="true" data-ai-panel>
    <header class="ai-header">
      <div class="ai-identity">
        <div class="ai-avatar">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons.bot}></svg>
        </div>
        <div>
          <p class="ai-name">Portfolio AI</p>
          <span class="ai-status"><span class="status-dot"></span>En ligne</span>
        </div>
      </div>
      <button class="ai-close" aria-label="Fermer l'assistant" data-ai-close>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons.x}></svg>
      </button>
    </header>

    <div class="ai-messages" data-ai-messages>
      <div class="message bot">
        <div class="msg-avatar">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons.bot}></svg>
        </div>
        <div class="msg-bubble">
          Bonjour ! Je suis l'assistant virtuel de {profile.firstName}. Comment puis-je vous aider ?
        </div>
      </div>
    </div>

    <div class="ai-quick-actions" data-ai-quick>
      {quickActions.map((action) => (
        <button class="quick-chip" data-quick-key={action.key}>{action.label}</button>
      ))}
    </div>

    <form class="ai-input-bar" data-ai-form>
      <input type="text" placeholder="Posez une question..." data-ai-input autocomplete="off" />
      <button type="submit" aria-label="Envoyer">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons.send}></svg>
      </button>
    </form>
  </div>
</div>

<style>
  .ai-assistant {
    position: fixed;
    bottom: 24px;
    left: 24px;
    z-index: 90;
  }

  .ai-toggle {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    border: 1px solid rgba(78, 205, 196, 0.4);
    background: rgba(12, 18, 31, 0.8);
    backdrop-filter: blur(14px);
    color: var(--primary);
    display: grid;
    place-items: center;
    cursor: pointer;
    position: relative;
    transition: transform 220ms ease, box-shadow 220ms ease;
  }

  :global(html[data-theme="light"]) .ai-toggle {
    background: rgba(255, 255, 255, 0.85);
    border-color: rgba(8, 145, 178, 0.4);
  }

  .ai-toggle:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(78, 205, 196, 0.3);
  }

  .ai-toggle svg {
    width: 26px;
    height: 26px;
  }

  .pulse-ring {
    position: absolute;
    inset: -4px;
    border-radius: 18px;
    border: 2px solid var(--primary);
    opacity: 0.6;
    animation: pulse-ring 2s ease-out infinite;
  }

  @keyframes pulse-ring {
    0% { transform: scale(1); opacity: 0.6; }
    100% { transform: scale(1.25); opacity: 0; }
  }

  .ai-panel {
    position: absolute;
    bottom: 70px;
    left: 0;
    width: 360px;
    max-height: 520px;
    border: 1px solid var(--border);
    border-radius: 20px;
    background: rgba(12, 18, 31, 0.95);
    backdrop-filter: blur(20px);
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: scale(0.9) translateY(20px);
    transform-origin: bottom left;
    pointer-events: none;
    transition: opacity 250ms ease, transform 250ms cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
  }

  :global(html[data-theme="light"]) .ai-panel {
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
  }

  .ai-panel.is-open {
    opacity: 1;
    transform: scale(1) translateY(0);
    pointer-events: auto;
  }

  .ai-header {
    padding: 14px 16px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .ai-identity {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .ai-avatar {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: var(--gradient-a);
    display: grid;
    place-items: center;
    color: #031117;
  }

  .ai-avatar svg {
    width: 20px;
    height: 20px;
  }

  .ai-name {
    margin: 0;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .ai-status {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.78rem;
    color: var(--muted);
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--success);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    50% { opacity: 0.5; }
  }

  .ai-close {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: none;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: background 180ms ease, color 180ms ease;
  }

  .ai-close:hover {
    background: rgba(255, 255, 255, 0.1);
    color: var(--text);
  }

  .ai-close svg {
    width: 18px;
    height: 18px;
  }

  .ai-messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    min-height: 200px;
    max-height: 280px;
  }

  .message {
    display: flex;
    gap: 10px;
    max-width: 90%;
  }

  .message.bot {
    align-self: flex-start;
  }

  .message.user {
    align-self: flex-end;
    flex-direction: row-reverse;
  }

  .msg-avatar {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: rgba(78, 205, 196, 0.2);
    display: grid;
    place-items: center;
    flex-shrink: 0;
  }

  .msg-avatar svg {
    width: 14px;
    height: 14px;
    color: var(--primary);
  }

  .msg-bubble {
    padding: 10px 14px;
    border-radius: 14px;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .message.bot .msg-bubble {
    background: rgba(255, 255, 255, 0.08);
    border-bottom-left-radius: 4px;
  }

  :global(html[data-theme="light"]) .message.bot .msg-bubble {
    background: rgba(0, 0, 0, 0.06);
  }

  .message.user .msg-bubble {
    background: linear-gradient(135deg, #4ecdc4 0%, #2563eb 100%);
    color: #fff;
    border-bottom-right-radius: 4px;
  }

  .msg-bubble a {
    color: var(--primary);
    text-decoration: underline;
  }

  .message.user .msg-bubble a {
    color: #c7f7f4;
  }

  .typing-indicator {
    display: flex;
    gap: 4px;
    padding: 10px 14px;
  }

  .typing-indicator span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--muted);
    animation: bounce 1.4s infinite ease-in-out;
  }

  .typing-indicator span:nth-child(1) { animation-delay: 0s; }
  .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
  .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes bounce {
    0%, 80%, 100% { transform: scale(0.8); }
    40% { transform: scale(1.2); }
  }

  .ai-quick-actions {
    padding: 0 16px 12px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .ai-quick-actions.is-hidden {
    display: none;
  }

  .quick-chip {
    padding: 8px 12px;
    border-radius: 999px;
    border: 1px solid rgba(78, 205, 196, 0.3);
    background: rgba(78, 205, 196, 0.1);
    color: var(--text);
    font-size: 0.82rem;
    cursor: pointer;
    transition: background 180ms ease, border-color 180ms ease;
  }

  .quick-chip:hover {
    background: rgba(78, 205, 196, 0.2);
    border-color: rgba(78, 205, 196, 0.5);
  }

  .ai-input-bar {
    padding: 12px 16px;
    border-top: 1px solid var(--border);
    display: flex;
    gap: 8px;
  }

  .ai-input-bar input {
    flex: 1;
    padding: 10px 14px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.06);
    color: var(--text);
    font-size: 0.9rem;
  }

  :global(html[data-theme="light"]) .ai-input-bar input {
    background: rgba(0, 0, 0, 0.04);
  }

  .ai-input-bar input:focus {
    outline: none;
    border-color: var(--primary);
  }

  .ai-input-bar input::placeholder {
    color: var(--muted);
  }

  .ai-input-bar button {
    width: 42px;
    height: 42px;
    border-radius: 10px;
    border: none;
    background: var(--gradient-a);
    color: #031117;
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }

  .ai-input-bar button:hover {
    transform: scale(1.05);
    box-shadow: 0 6px 20px rgba(78, 205, 196, 0.3);
  }

  .ai-input-bar button svg {
    width: 18px;
    height: 18px;
  }

  @media (max-width: 768px) {
    .ai-assistant {
      bottom: 16px;
      left: 16px;
    }

    .ai-toggle {
      width: 48px;
      height: 48px;
    }

    .ai-toggle svg {
      width: 22px;
      height: 22px;
    }

    .ai-panel {
      width: calc(100vw - 32px);
      max-width: 360px;
      bottom: 60px;
    }
  }
</style>

<script>
  // AI Assistant chatbot functionality
  const assistant = document.querySelector("[data-ai-assistant]") as HTMLElement;
  if (assistant) {
    const toggle = assistant.querySelector("[data-ai-toggle]") as HTMLButtonElement;
    const panel = assistant.querySelector("[data-ai-panel]") as HTMLElement;
    const closeBtn = assistant.querySelector("[data-ai-close]") as HTMLButtonElement;
    const messagesContainer = assistant.querySelector("[data-ai-messages]") as HTMLElement;
    const quickActionsContainer = assistant.querySelector("[data-ai-quick]") as HTMLElement;
    const form = assistant.querySelector("[data-ai-form]") as HTMLFormElement;
    const input = assistant.querySelector("[data-ai-input]") as HTMLInputElement;

    // Parse profile data
    const profileData = JSON.parse(assistant.dataset.profile || "{}");
    const quickActions = JSON.parse(assistant.dataset.quickActions || "[]");

    // Bot icon for messages
    const botIcon = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v2"/><rect width="20" height="12" x="2" y="8" rx="2"/><path d="M6 15h.01M10 15h.01M14 15h.01M18 15h.01"/></svg>`;

    // Mini markdown renderer
    const renderMarkdown = (text: string): string => {
      return text
        .replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")
        .replace(/\*(.+?)\*/g, "<em>$1</em>")
        .replace(/\[(.+?)\]\((.+?)\)/g, '<a href="$2" target="_blank" rel="noreferrer">$1</a>');
    };

    // Build knowledge base responses
    const getResponse = (query: string): string => {
      const q = query.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
      
      // Greetings
      if (/^(bonjour|salut|hello|hi|hey|coucou)/i.test(q)) {
        return `Bonjour ! Je suis l'assistant virtuel de **${profileData.fullName}**. Comment puis-je vous aider aujourd'hui ?`;
      }

      // About / Who is
      if (/qui (est|es)|about|a propos|presentation|profil/i.test(q)) {
        const aboutText = profileData.about?.map((b: any) => b.text).join(" ") || "";
        return `**${profileData.fullName}** est ${profileData.title}. ${aboutText.slice(0, 200)}... [En savoir plus](#about)`;
      }

      // Skills / Competences
      if (/competence|skill|tech|technologie|maitrise|sait faire/i.test(q)) {
        const skills = profileData.technicalSkills?.map((cat: any) => 
          `**${cat.category}**: ${cat.items.join(", ")}`
        ).join("\n") || "Pas de compétences renseignées.";
        return `Voici les compétences de ${profileData.firstName}:\n\n${skills}\n\n[Voir toutes les compétences](#skills)`;
      }

      // Specific technology check
      const techMatch = q.match(/(?:connait|maitrise|sait|utilise|fait du|code en)\s+(\w+)/i);
      if (techMatch) {
        const tech = techMatch[1].toLowerCase();
        const allTechs = profileData.technicalSkills?.flatMap((cat: any) => 
          cat.items.map((i: string) => i.toLowerCase())
        ) || [];
        if (allTechs.includes(tech)) {
          return `Oui, **${profileData.firstName}** maîtrise ${techMatch[1]} ! [Voir les compétences](#skills)`;
        } else {
          return `${techMatch[1]} n'est pas listé dans les compétences actuelles.`;
        }
      }

      // Education
      if (/education|etude|diplome|formation|parcours|universite|ecole/i.test(q)) {
        if (profileData.education?.length > 0) {
          const edu = profileData.education[0];
          return `**${edu.degree}** en ${edu.field} à *${edu.institution}* (${edu.period}). [Voir le parcours](#education)`;
        }
        return "Le parcours académique n'est pas encore renseigné.";
      }

      // Experience
      if (/experience|stage|travail|emploi|job|poste/i.test(q)) {
        if (profileData.experience?.length > 0) {
          const exp = profileData.experience[0];
          return `**${exp.role}** chez *${exp.organization}* (${exp.period}). ${exp.description?.slice(0, 100)}... [Voir l'expérience](#experience)`;
        }
        return `${profileData.firstName} est actuellement à la recherche d'opportunités. ${profileData.availabilityBadge}`;
      }

      // Publications
      if (/publication|article|recherche|paper|research/i.test(q)) {
        if (profileData.publications?.length > 0) {
          return `${profileData.firstName} a **${profileData.publications.length}** publication(s). [Voir les publications](#publications)`;
        }
        return "Pas de publications académiques pour le moment.";
      }

      // Projects
      if (/projet|project|realisation|portfolio|creation/i.test(q)) {
        if (profileData.projects?.length > 0) {
          const projectList = profileData.projects.slice(0, 3).map((p: any) => 
            `• **${p.title}**: ${p.description?.slice(0, 60)}...`
          ).join("\n");
          return `Voici quelques projets:\n\n${projectList}\n\n[Voir tous les projets](#projects)`;
        }
        return "Pas de projets renseignés pour le moment.";
      }

      // Contact
      if (/contact|email|mail|telephone|joindre|ecrire/i.test(q)) {
        const contactInfo = [];
        if (profileData.contact?.email) contactInfo.push(`Email: **${profileData.contact.email}**`);
        if (profileData.contact?.phone) contactInfo.push(`Tél: **${profileData.contact.phone}**`);
        if (profileData.contact?.location) contactInfo.push(`Lieu: **${profileData.contact.location}**`);
        return contactInfo.length > 0 
          ? `Vous pouvez contacter ${profileData.firstName} via:\n\n${contactInfo.join("\n")}\n\n[Formulaire de contact](#contact)`
          : "Pas d'informations de contact disponibles.";
      }

      // Social links
      if (/github|linkedin|social|reseau|profil en ligne/i.test(q)) {
        const links = profileData.socialLinks?.map((s: any) => 
          `[${s.label}](${s.href})`
        ).join(" • ") || "";
        return links ? `Profils en ligne: ${links}` : "Pas de liens sociaux renseignés.";
      }

      // Stats
      if (/stat|chiffre|nombre/i.test(q)) {
        const stats = profileData.stats?.map((s: any) => 
          `**${s.value}** ${s.label}`
        ).join(" | ") || "";
        return stats || "Pas de statistiques disponibles.";
      }

      // Thanks
      if (/merci|thanks|thank you/i.test(q)) {
        return "De rien ! N'hésitez pas si vous avez d'autres questions. 😊";
      }

      // Help
      if (/aide|help|quoi demander|que sais/i.test(q)) {
        return `Je peux vous renseigner sur:\n• **Qui est ${profileData.firstName}**\n• Ses **compétences**\n• Son **parcours**\n• Ses **projets**\n• Comment le **contacter**\n\nPosez votre question !`;
      }

      // Fallback
      return `Je ne suis pas sûr de comprendre. Essayez de demander:\n• Qui est ${profileData.firstName} ?\n• Quelles sont ses compétences ?\n• Ses projets\n• Comment le contacter`;
    };

    // Add message to chat
    const addMessage = (text: string, isUser: boolean) => {
      const msg = document.createElement("div");
      msg.className = `message ${isUser ? "user" : "bot"}`;
      
      if (!isUser) {
        msg.innerHTML = `
          <div class="msg-avatar">${botIcon}</div>
          <div class="msg-bubble">${renderMarkdown(text)}</div>
        `;
      } else {
        msg.innerHTML = `<div class="msg-bubble">${text}</div>`;
      }
      
      messagesContainer.appendChild(msg);
      messagesContainer.scrollTop = messagesContainer.scrollHeight;

      // Handle section links
      msg.querySelectorAll("a[href^='#']").forEach((link) => {
        link.addEventListener("click", (e) => {
          e.preventDefault();
          const href = (link as HTMLAnchorElement).getAttribute("href");
          if (href) {
            panel.classList.remove("is-open");
            document.querySelector(href)?.scrollIntoView({ behavior: "smooth" });
          }
        });
      });
    };

    // Show typing indicator
    const showTyping = (): HTMLElement => {
      const typing = document.createElement("div");
      typing.className = "message bot";
      typing.innerHTML = `
        <div class="msg-avatar">${botIcon}</div>
        <div class="typing-indicator"><span></span><span></span><span></span></div>
      `;
      messagesContainer.appendChild(typing);
      messagesContainer.scrollTop = messagesContainer.scrollHeight;
      return typing;
    };

    // Handle user input
    const handleInput = (text: string) => {
      if (!text.trim()) return;

      // Hide quick actions after first interaction
      quickActionsContainer.classList.add("is-hidden");

      // Add user message
      addMessage(text, true);

      // Show typing indicator
      const typingEl = showTyping();

      // Respond after delay
      setTimeout(() => {
        typingEl.remove();
        const response = getResponse(text);
        addMessage(response, false);
      }, 600 + Math.random() * 400);
    };

    // Toggle panel
    toggle.addEventListener("click", () => {
      panel.classList.toggle("is-open");
      if (panel.classList.contains("is-open")) {
        input.focus();
      }
    });

    // Close panel
    closeBtn.addEventListener("click", () => panel.classList.remove("is-open"));

    // Close on Escape
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && panel.classList.contains("is-open")) {
        panel.classList.remove("is-open");
      }
    });

    // Form submit
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      handleInput(input.value);
      input.value = "";
    });

    // Quick actions
    quickActionsContainer.querySelectorAll(".quick-chip").forEach((chip) => {
      chip.addEventListener("click", () => {
        const key = (chip as HTMLElement).dataset.quickKey;
        const action = quickActions.find((a: any) => a.key === key);
        if (action) {
          handleInput(action.label);
        }
      });
    });
  }
</script>
