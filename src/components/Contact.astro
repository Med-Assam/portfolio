---
/**
 * Contact area with profile channels and a functional FormSubmit form.
 */
import type { ProfileData } from "../data/profile";

type Props = { profile: ProfileData };
const { profile } = Astro.props;

const icons: Record<string, string> = {
  mail: `<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-10 6L2 7"/>`,
  linkedin: `<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>`,

  phone: `<path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.1-8.7A2 2 0 0 1 4 2h3a2 2 0 0 1 2 1.7c.1.8.3 1.5.6 2.2a2 2 0 0 1-.4 2.1L8 9.2a16 16 0 0 0 6.8 6.8l1.2-1.2a2 2 0 0 1 2.1-.4c.7.3 1.4.5 2.2.6A2 2 0 0 1 22 16.9Z"/>`,
  map: `<path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 1 1 16 0Z"/><circle cx="12" cy="10" r="3"/>`,
  send: `<path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/>`,
  github: `<path d="M15 22v-4a4 4 0 0 0-1-2.8c3.2-.35 6.5-1.6 6.5-7.2A5.6 5.6 0 0 0 19 4.3 5.2 5.2 0 0 0 18.9 1s-1.2-.4-3.9 1.5a13.4 13.4 0 0 0-7 0C5.3.6 4.1 1 4.1 1A5.2 5.2 0 0 0 4 4.3a5.6 5.6 0 0 0-1.5 3.7c0 5.6 3.3 6.8 6.5 7.2A4 4 0 0 0 8 18v4"/><path d="M9 18c-4.5 2-5-2-7-2"/>`,
  link: `<path d="M10 13a5 5 0 0 0 7.07 0l3.54-3.54a5 5 0 1 0-7.07-7.07L11 4"/><path d="M14 11a5 5 0 0 0-7.07 0L3.39 14.54a5 5 0 1 0 7.07 7.07L13 20"/>`
};

const contactCards = [
  profile.contact.email
    ? { label: "Email", value: profile.contact.email, href: `mailto:${profile.contact.email}`, icon: "mail" }
    : null,
  profile.contact.phone
    ? { label: "Telephone", value: profile.contact.phone, href: `tel:${profile.contact.phone}`, icon: "phone" }
    : null,
  profile.contact.location
    ? { label: "Localisation", value: profile.contact.location, href: undefined, icon: "map" }
    : null
].filter(Boolean) as Array<{ label: string; value: string; href?: string; icon: string }>;

const formAction = profile.contact.email
  ? `https://formsubmit.co/ajax/${profile.contact.email}`
  : "https://formsubmit.co/ajax/"

const toastIcons: Record<string, string> = {
  check: `<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>`,
  alert: `<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>`,
  x: `<path d="M18 6 6 18"/><path d="M6 6l12 12"/>`
};
---

<section id="contact" class="section">
  <div class="container">
    <p class="section-kicker reveal">Contact</p>
    <h2 class="section-title reveal" data-delay="20">Discutons de votre projet</h2>

    <div class="contact-grid">
      <div class="contact-info reveal" data-delay="60">
        <div class="info-stack">
          {contactCards.map((item) => (
            <article class="glass-card info-card">
              <span class="info-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[item.icon]}></svg>
              </span>
              <div>
                <p class="label">{item.label}</p>
                {item.href ? <a href={item.href}>{item.value}</a> : <p class="value">{item.value}</p>}
              </div>
            </article>
          ))}
        </div>

        <div class="social-row">
          {profile.socialLinks.map((social) => (
            <a href={social.href} target="_blank" rel="noreferrer" aria-label={social.label}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[social.icon] ?? icons.link}></svg>
            </a>
          ))}
        </div>
      </div>

      <form class="glass-card contact-form reveal" data-delay="90" data-contact-form data-action={formAction}>
        <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

        <label for="name">Nom</label>
        <input id="name" name="name" type="text" required />

        <label for="email">Email</label>
        <input id="email" name="email" type="email" required />

        <label for="subject">Sujet</label>
        <input id="subject" name="subject" type="text" required />

        <label for="message">Message</label>
        <textarea id="message" name="message" rows="5" required></textarea>

        <button type="submit" data-submit-btn>
          <span class="btn-text">Envoyer</span>
          <span class="btn-spinner"></span>
          <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons.send}></svg>
        </button>
      </form>
    </div>
  </div>
</section>

<!-- Toast Overlay -->
<div class="toast-overlay" data-toast-overlay aria-hidden="true">
  <div class="toast-backdrop" data-toast-backdrop></div>
  <div class="toast-content glass-card" data-toast-content>
    <button class="toast-close" data-toast-close aria-label="Fermer">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={toastIcons.x}></svg>
    </button>
    <div class="toast-icon success" data-toast-icon-success>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={toastIcons.check}></svg>
    </div>
    <div class="toast-icon error" data-toast-icon-error>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={toastIcons.alert}></svg>
    </div>
    <h3 class="toast-title" data-toast-title>Message envoyé !</h3>
    <p class="toast-message" data-toast-message>Merci pour votre message. Je vous répondrai dès que possible.</p>
    <button class="toast-btn" data-toast-btn>Fermer</button>
  </div>
</div>

<style>
  .contact-grid {
    margin-top: 22px;
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 14px;
  }

  .info-stack {
    display: grid;
    gap: 10px;
  }

  .info-card {
    padding: 14px;
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .info-icon {
    width: 42px;
    height: 42px;
    border-radius: 11px;
    display: grid;
    place-items: center;
    background: rgba(78, 205, 196, 0.14);
    border: 1px solid rgba(78, 205, 196, 0.35);
    transition: transform 220ms ease, box-shadow 220ms ease;
  }

  .info-card:hover .info-icon {
    transform: scale(1.08);
    box-shadow: 0 0 16px rgba(78, 205, 196, 0.24);
  }

  .info-icon svg {
    width: 17px;
    height: 17px;
  }

  .label {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.72rem;
    font-family: var(--font-mono);
    color: var(--muted);
  }

  .value,
  .info-card a {
    margin: 4px 0 0;
    color: #deebff;
    font-weight: 530;
  }

  .social-row {
    margin-top: 12px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .social-row a {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.05);
    display: grid;
    place-items: center;
    transition: transform 220ms ease, box-shadow 220ms ease;
  }

  .social-row a:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.22);
  }

  .social-row svg {
    width: 16px;
    height: 16px;
  }

  .contact-form {
    padding: 18px;
    display: grid;
    gap: 8px;
  }

  .contact-form label {
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.72rem;
    color: var(--muted);
    font-family: var(--font-mono);
  }

  .contact-form input,
  .contact-form textarea {
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(6, 11, 22, 0.74);
    color: #e6eeff;
    padding: 10px 12px;
    transition: border-color 160ms ease, box-shadow 160ms ease;
  }

  .contact-form input:focus,
  .contact-form textarea:focus {
    border-color: rgba(78, 205, 196, 0.55);
    box-shadow: 0 0 0 3px rgba(78, 205, 196, 0.14);
    outline: none;
  }

  .contact-form button {
    margin-top: 10px;
    border: none;
    border-radius: 12px;
    background: var(--gradient-a);
    color: #041018;
    font-weight: 700;
    padding: 12px 16px;
    cursor: pointer;
    display: inline-flex;
    gap: 8px;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    transition: box-shadow 220ms ease;
  }

  .contact-form button svg.btn-icon {
    width: 16px;
    height: 16px;
    transition: opacity 200ms ease;
  }

  .contact-form button .btn-text {
    transition: opacity 200ms ease;
  }

  .contact-form button .btn-spinner {
    position: absolute;
    width: 18px;
    height: 18px;
    border: 2px solid transparent;
    border-top-color: currentColor;
    border-radius: 50%;
    opacity: 0;
    animation: spin 0.8s linear infinite;
  }

  .contact-form button.loading .btn-text,
  .contact-form button.loading .btn-icon {
    opacity: 0;
  }

  .contact-form button.loading .btn-spinner {
    opacity: 1;
  }

  .contact-form button.loading {
    pointer-events: none;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .contact-form button:hover {
    box-shadow: 0 12px 26px rgba(78, 205, 196, 0.3);
  }

  /* Toast Overlay */
  .toast-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: grid;
    place-items: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 300ms ease, visibility 300ms ease;
  }

  .toast-overlay.show {
    opacity: 1;
    visibility: visible;
  }

  .toast-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(6, 11, 22, 0.85);
    backdrop-filter: blur(6px);
  }

  .toast-content {
    position: relative;
    max-width: 400px;
    width: 90%;
    padding: 32px;
    text-align: center;
    transform: translateY(20px) scale(0.95);
    transition: transform 300ms ease;
  }

  .toast-overlay.show .toast-content {
    transform: translateY(0) scale(1);
  }

  .toast-close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 32px;
    height: 32px;
    border: none;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: background 200ms ease;
  }

  .toast-close:hover {
    background: rgba(255, 255, 255, 0.15);
  }

  .toast-close svg {
    width: 16px;
    height: 16px;
    stroke: var(--muted);
  }

  .toast-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 20px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    animation: popIn 400ms ease;
  }

  @keyframes popIn {
    0% { transform: scale(0); }
    50% { transform: scale(1.15); }
    100% { transform: scale(1); }
  }

  .toast-icon.success {
    background: rgba(78, 205, 196, 0.18);
    border: 2px solid rgba(78, 205, 196, 0.5);
    display: none;
  }

  .toast-icon.success svg {
    width: 28px;
    height: 28px;
    stroke: var(--accent-primary);
  }

  .toast-icon.error {
    background: rgba(255, 107, 107, 0.18);
    border: 2px solid rgba(255, 107, 107, 0.5);
    display: none;
  }

  .toast-icon.error svg {
    width: 28px;
    height: 28px;
    stroke: #ff6b6b;
  }

  .toast-overlay.success .toast-icon.success {
    display: grid;
  }

  .toast-overlay.error .toast-icon.error {
    display: grid;
  }

  .toast-title {
    margin: 0 0 10px;
    font-size: 1.4rem;
    color: #fff;
  }

  .toast-message {
    margin: 0 0 24px;
    color: var(--muted);
    line-height: 1.6;
  }

  .toast-btn {
    border: none;
    border-radius: 10px;
    background: var(--gradient-a);
    color: #041018;
    font-weight: 700;
    padding: 12px 32px;
    cursor: pointer;
    transition: box-shadow 200ms ease, transform 200ms ease;
  }

  .toast-btn:hover {
    box-shadow: 0 10px 20px rgba(78, 205, 196, 0.3);
    transform: translateY(-2px);
  }

  @media (max-width: 920px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.querySelector('[data-contact-form]') as HTMLFormElement;
    const submitBtn = document.querySelector('[data-submit-btn]') as HTMLButtonElement;
    const toastOverlay = document.querySelector('[data-toast-overlay]') as HTMLElement;
    const toastClose = document.querySelector('[data-toast-close]') as HTMLButtonElement;
    const toastBtn = document.querySelector('[data-toast-btn]') as HTMLButtonElement;
    const toastBackdrop = document.querySelector('[data-toast-backdrop]') as HTMLElement;
    const toastTitle = document.querySelector('[data-toast-title]') as HTMLElement;
    const toastMessage = document.querySelector('[data-toast-message]') as HTMLElement;

    if (!form) return;

    const formAction = form.dataset.action || '';

    const showToast = (type: 'success' | 'error', title: string, message: string) => {
      toastOverlay.classList.remove('success', 'error');
      toastOverlay.classList.add(type, 'show');
      toastOverlay.setAttribute('aria-hidden', 'false');
      toastTitle.textContent = title;
      toastMessage.textContent = message;
      document.body.style.overflow = 'hidden';
    };

    const hideToast = () => {
      toastOverlay.classList.remove('show');
      toastOverlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };

    toastClose?.addEventListener('click', hideToast);
    toastBtn?.addEventListener('click', hideToast);
    toastBackdrop?.addEventListener('click', hideToast);

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Anti-bot honeypot check
      const honeypot = form.querySelector('input[name="_honey"]') as HTMLInputElement;
      if (honeypot?.value) return;

      submitBtn.classList.add('loading');

      const formData = new FormData(form);
      const data: Record<string, string> = {};
      formData.forEach((value, key) => {
        if (key !== '_honey') data[key] = value.toString();
      });

      try {
        const response = await fetch(formAction, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify(data)
        });

        if (response.ok) {
          showToast('success', 'Message envoyé !', 'Merci pour votre message. Je vous répondrai dès que possible.');
          form.reset();
        } else {
          throw new Error('Erreur de soumission');
        }
      } catch (error) {
        showToast('error', 'Erreur d\'envoi', 'Une erreur est survenue. Veuillez réessayer ou me contacter directement par email.');
      } finally {
        submitBtn.classList.remove('loading');
      }
    });
  });
</script>
