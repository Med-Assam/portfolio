---
/**
 * Hero section with profile summary, adaptive calls-to-action and key stats.
 */
import type { ProfileData } from "../data/profile";

type Props = { profile: ProfileData };
const { profile } = Astro.props;

const icons: Record<string, string> = {
  github: `<path d="M15 22v-4a4 4 0 0 0-1-2.8c3.2-.35 6.5-1.6 6.5-7.2A5.6 5.6 0 0 0 19 4.3 5.2 5.2 0 0 0 18.9 1s-1.2-.4-3.9 1.5a13.4 13.4 0 0 0-7 0C5.3.6 4.1 1 4.1 1A5.2 5.2 0 0 0 4 4.3a5.6 5.6 0 0 0-1.5 3.7c0 5.6 3.3 6.8 6.5 7.2A4 4 0 0 0 8 18v4"/><path d="M9 18c-4.5 2-5-2-7-2"/>`,
  linkedin: `<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>`,
  download: `<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/>`,

  mail: `<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-10 6L2 7"/>`,
  link: `<path d="M10 13a5 5 0 0 0 7.07 0l3.54-3.54a5 5 0 1 0-7.07-7.07L11 4"/><path d="M14 11a5 5 0 0 0-7.07 0L3.39 14.54a5 5 0 1 0 7.07 7.07L13 20"/>`
};
---

<section id="hero" class="section hero-section">
  <div class="container hero-grid">
    <div class="hero-content reveal">
      <p class="status-badge">
        <span class="status-dot" aria-hidden="true"></span>
        {profile.availabilityBadge}
      </p>

      <h1 class="hero-name">{profile.fullName}</h1>
      <p class="hero-title">{profile.title}</p>
      <p class="hero-subtitle">{profile.subtitle}</p>

      <div class="hero-actions">
        {profile.heroActions.map((action, idx) => (
          <a
            href={action.href}
            class={`hero-btn ${idx === 0 ? "is-primary" : "is-secondary"}`}
            target={action.href.startsWith("http") ? "_blank" : undefined}
            rel={action.href.startsWith("http") ? "noreferrer" : undefined}
          >
            {action.label}
          </a>
        ))}
        <button class="hero-btn is-download" data-resume-trigger>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons.download}></svg>
          <span>Download CV</span>
        </button>
      </div>

      <div class="social-pills">
        {profile.socialLinks.map((social) => (
          <a href={social.href} target="_blank" rel="noreferrer" class="social-pill">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[social.icon] ?? icons.link}></svg>
            <span>{social.label}</span>
          </a>
        ))}
      </div>
    </div>

    <div class="hero-media reveal" data-delay="80">
      <div class="avatar-ring">
        <img src={profile.avatar} alt={`Photo de ${profile.fullName}`} loading="eager" decoding="async" />
      </div>
    </div>
  </div>

  {profile.stats.length > 0 && (
    <div class="container reveal" data-delay="130">
      <div class="stats-grid glass-card">
        {profile.stats.map((stat) => (
          <article class="stat-item">
            <p class="stat-value">{stat.value}</p>
            <p class="stat-label">{stat.label}</p>
          </article>
        ))}
      </div>
    </div>
  )}

  <div class="scroll-indicator" aria-hidden="true">
    <span class="mouse"><span class="wheel"></span></span>
  </div>
</section>

<style>
  .hero-section {
    min-height: 96vh;
    display: grid;
    align-content: center;
    position: relative;
    padding-top: 26px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 28px;
    align-items: center;
  }

  .status-badge {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    border-radius: 999px;
    border: 1px solid rgba(61, 220, 151, 0.45);
    color: #b9ffd8;
    background: rgba(61, 220, 151, 0.12);
    font-size: 0.88rem;
  }

  .status-dot {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: var(--success);
    box-shadow: 0 0 0 0 rgba(61, 220, 151, 0.55);
    animation: pulse 1.8s infinite;
  }

  .hero-name {
    margin: 16px 0 4px;
    font-size: clamp(2.2rem, 4vw, 4.2rem);
    line-height: 1.05;
    background: var(--gradient-a);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    background-size: 220% 220%;
    animation: gradientShift 8s ease-in-out infinite;
  }

  .hero-title {
    margin: 0;
    color: #d7e3ff;
    font-size: clamp(1.1rem, 1rem + 0.9vw, 1.8rem);
    font-weight: 560;
  }

  .hero-subtitle {
    max-width: 62ch;
    color: var(--muted);
    margin: 14px 0 0;
  }

  .hero-actions {
    margin-top: 22px;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .hero-btn {
    padding: 12px 16px;
    border-radius: 12px;
    border: 1px solid transparent;
    transition: transform 220ms ease, box-shadow 220ms ease;
  }

  .hero-btn.is-primary {
    background: var(--gradient-a);
    color: #041017;
    font-weight: 700;
  }

  .hero-btn.is-secondary {
    border-color: var(--border);
    background: rgba(11, 17, 31, 0.62);
  }

  .hero-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 26px rgba(0, 0, 0, 0.28);
  }

  .hero-btn.is-download {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-color: rgba(78, 205, 196, 0.4);
    background: rgba(78, 205, 196, 0.12);
    color: var(--text);
    cursor: pointer;
    font-weight: 500;
  }

  .hero-btn.is-download svg {
    width: 18px;
    height: 18px;
  }

  .hero-btn.is-download:hover {
    background: rgba(78, 205, 196, 0.22);
    box-shadow: 0 16px 26px rgba(78, 205, 196, 0.18);
  }

  .social-pills {
    margin-top: 16px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .social-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--border);
    background: rgba(15, 22, 38, 0.56);
    backdrop-filter: blur(10px);
    color: #d8e6ff;
    border-radius: 999px;
    padding: 8px 12px;
  }

  .social-pill svg {
    width: 15px;
    height: 15px;
  }

  .avatar-ring {
    width: min(360px, 100%);
    margin-inline: auto;
    border-radius: 26px;
    padding: 6px;
    background: conic-gradient(from 120deg, #4ecdc4, #76e4f7, #ff7b72, #4ecdc4);
    animation: hueCycle 8s linear infinite;
    transition: transform 420ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .avatar-ring:hover {
    transform: scale(1.04);
  }

  .avatar-ring img {
    width: 100%;
    aspect-ratio: 1 / 1;
    display: block;
    object-fit: cover;
    border-radius: 22px;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .stats-grid {
    margin-top: 26px;
    padding: 16px;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  .stat-item {
    padding: 8px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.04);
  }

  .stat-value {
    margin: 0;
    font-size: clamp(1.15rem, 0.95rem + 1vw, 1.8rem);
    font-weight: 760;
    background: var(--gradient-a);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .stat-label {
    margin: 4px 0 0;
    color: var(--muted);
    font-size: 0.84rem;
  }

  .scroll-indicator {
    margin-top: 30px;
    display: flex;
    justify-content: center;
  }

  .mouse {
    width: 26px;
    height: 44px;
    border-radius: 999px;
    border: 1px solid var(--border);
    display: grid;
    place-items: start center;
    padding-top: 7px;
  }

  .wheel {
    width: 4px;
    height: 10px;
    border-radius: 999px;
    background: var(--primary);
    animation: scrollWheel 1.5s ease-in-out infinite;
  }

  @keyframes gradientShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  @keyframes pulse {
    70% { box-shadow: 0 0 0 10px rgba(61, 220, 151, 0); }
    100% { box-shadow: 0 0 0 0 rgba(61, 220, 151, 0); }
  }

  @keyframes hueCycle {
    to { filter: hue-rotate(360deg); }
  }

  @keyframes scrollWheel {
    0%, 100% { transform: translateY(0); opacity: 1; }
    60% { transform: translateY(11px); opacity: 0.2; }
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .hero-media {
      order: -1;
    }

    .avatar-ring {
      width: min(220px, 72vw);
    }

    .stats-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>

<script>
  // Resume download button triggers the export modal
  const resumeTrigger = document.querySelector("[data-resume-trigger]");
  if (resumeTrigger) {
    resumeTrigger.addEventListener("click", () => {
      document.dispatchEvent(new CustomEvent("open-resume-modal"));
    });
  }
</script>
