---
/**
 * Education timeline section with latest badge.
 */
import type { ProfileData } from "../data/profile";

type Props = { profile: ProfileData };
const { profile } = Astro.props;

const icons: Record<string, string> = {
  external: `<path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>`
};
---

<section id="education" class="section">
  <div class="container">
    <p class="section-kicker reveal">Education</p>
    <h2 class="section-title reveal" data-delay="20">Parcours academique</h2>

    <div class="timeline">
      {profile.education.map((item, index) => (
        <article class="glass-card edu-card reveal" data-delay={String(60 + index * 45)}>
          <span class="dot" aria-hidden="true"></span>
          {item.latest && <span class="latest">Latest</span>}
          <p class="period">{item.period}</p>
          <h3>{item.degree}</h3>
          <p class="field">{item.field}</p>
          <a href={item.institutionUrl} target="_blank" rel="noreferrer" class="institution">
            <span>{item.institution}</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons.external}></svg>
          </a>
          <p class="desc">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline {
    margin-top: 22px;
    position: relative;
    padding-left: 26px;
    display: grid;
    gap: 14px;
  }

  .timeline::before {
    content: "";
    position: absolute;
    left: 11px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: linear-gradient(to bottom, rgba(78, 205, 196, 0.65), rgba(255, 123, 114, 0.45));
  }

  .edu-card {
    position: relative;
    padding: 18px;
  }

  .dot {
    position: absolute;
    left: -22px;
    top: 26px;
    width: 12px;
    height: 12px;
    border-radius: 999px;
    background: var(--gradient-a);
    box-shadow: 0 0 0 7px rgba(78, 205, 196, 0.12);
    animation: glow 2s ease-in-out infinite;
  }

  .latest,
  .period {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .latest {
    display: inline-block;
    padding: 4px 8px;
    border-radius: 999px;
    background: rgba(78, 205, 196, 0.14);
    border: 1px solid rgba(78, 205, 196, 0.45);
    margin-bottom: 8px;
  }

  .period {
    color: var(--muted);
    margin: 0;
  }

  .edu-card h3 {
    margin: 6px 0 2px;
  }

  .field {
    margin: 0;
    color: var(--primary);
    font-weight: 600;
  }

  .institution {
    margin-top: 10px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #d2defb;
  }

  .institution svg {
    width: 14px;
    height: 14px;
  }

  .desc {
    margin: 8px 0 0;
    color: var(--muted);
  }

  @keyframes glow {
    50% { box-shadow: 0 0 0 11px rgba(78, 205, 196, 0.05); }
  }

  @media (max-width: 768px) {
    .timeline {
      padding-left: 0;
    }

    .timeline::before,
    .dot {
      display: none;
    }
  }
</style>
