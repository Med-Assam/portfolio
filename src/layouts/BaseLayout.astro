---
/**
 * Base layout handling document shell, global styles, ambient background,
 * reveal animations and shared structural elements.
 */
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BackToTop from "../components/BackToTop.astro";
import AiAssistant from "../components/AiAssistant.astro";
import ResumeExport from "../components/ResumeExport.astro";
import { navItems, profile } from "../data/profile";

const pageTitle = `${profile.fullName} | Portfolio`;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={`Portfolio de ${profile.fullName}`} />
    <meta name="theme-color" content="#0a0f1e" />
    <title>{pageTitle}</title>
    <!-- Prevent FOUC: Apply saved theme before render -->
    <script is:inline>
      (function() {
        const saved = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = saved || (prefersDark ? 'dark' : 'dark');
        document.documentElement.setAttribute('data-theme', theme);
        document.querySelector('meta[name="theme-color"]')?.setAttribute('content', theme === 'light' ? '#f8fafc' : '#0a0f1e');
      })();
    </script>
    <style is:global>
      :root {
        --bg: #0a0f1e;
        --bg-elev: #0f162a;
        --surface: rgba(17, 24, 39, 0.55);
        --text: #e8ecf7;
        --muted: #9ba5c4;
        --primary: #4ecdc4;
        --accent: #ff7b72;
        --success: #3ddc97;
        --warning: #ffb454;
        --border: rgba(255, 255, 255, 0.12);
        --glow: rgba(78, 205, 196, 0.22);
        --gradient-a: linear-gradient(135deg, #4ecdc4 0%, #76e4f7 45%, #ff7b72 100%);
        --gradient-b: linear-gradient(120deg, #1f2a44 0%, #18223b 48%, #111a33 100%);
        --radius-sm: 12px;
        --radius-md: 18px;
        --radius-lg: 28px;
        --shadow-soft: 0 14px 40px rgba(0, 0, 0, 0.28);
        --shadow-glow: 0 0 0 1px var(--border), 0 18px 50px rgba(78, 205, 196, 0.14);
        --max-width: 1180px;
        --font-sans: "Inter", "Segoe UI", sans-serif;
        --font-mono: "JetBrains Mono", "Consolas", monospace;
      }

      /* Light theme overrides */
      html[data-theme="light"] {
        --bg: #f8fafc;
        --bg-elev: #ffffff;
        --surface: rgba(255, 255, 255, 0.85);
        --text: #0f172a;
        --muted: #64748b;
        --primary: #0891b2;
        --accent: #e11d48;
        --success: #059669;
        --warning: #d97706;
        --border: rgba(0, 0, 0, 0.12);
        --glow: rgba(8, 145, 178, 0.18);
        --gradient-a: linear-gradient(135deg, #0891b2 0%, #06b6d4 45%, #e11d48 100%);
        --gradient-b: linear-gradient(120deg, #f1f5f9 0%, #e2e8f0 48%, #cbd5e1 100%);
        --shadow-soft: 0 14px 40px rgba(0, 0, 0, 0.08);
        --shadow-glow: 0 0 0 1px var(--border), 0 18px 50px rgba(8, 145, 178, 0.1);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        color: var(--text);
        font-family: var(--font-sans);
        background: var(--bg);
        line-height: 1.6;
        overflow-x: hidden;
      }

      body.menu-open {
        overflow: hidden;
      }

      ::selection {
        background: rgba(78, 205, 196, 0.3);
        color: #f5fbff;
      }

      a,
      button,
      input,
      textarea {
        font: inherit;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      a:focus-visible,
      button:focus-visible,
      input:focus-visible,
      textarea:focus-visible {
        outline: 2px solid var(--primary);
        outline-offset: 3px;
      }

      .skip-link {
        position: absolute;
        left: -999px;
        top: 12px;
        z-index: 200;
        border-radius: 999px;
        background: #f2fdff;
        color: #051018;
        padding: 10px 16px;
        font-weight: 700;
      }

      .skip-link:focus-visible {
        left: 12px;
      }

      .site-bg {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: -1;
        background:
          linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
        background-size: 36px 36px;
      }

      .site-bg::before,
      .site-bg::after {
        content: "";
        position: absolute;
        filter: blur(70px);
        opacity: 0.65;
        border-radius: 999px;
        animation: drift 22s ease-in-out infinite alternate;
      }

      .site-bg::before {
        width: 360px;
        height: 360px;
        left: -120px;
        top: 5%;
        background: rgba(78, 205, 196, 0.28);
      }

      .site-bg::after {
        width: 300px;
        height: 300px;
        right: -80px;
        bottom: 8%;
        background: rgba(255, 123, 114, 0.24);
        animation-delay: 1.4s;
      }

      html[data-theme="light"] .site-bg {
        background:
          linear-gradient(rgba(0, 0, 0, 0.04) 1px, transparent 1px),
          linear-gradient(90deg, rgba(0, 0, 0, 0.04) 1px, transparent 1px);
        background-size: 36px 36px;
      }

      html[data-theme="light"] .site-bg::before {
        background: rgba(8, 145, 178, 0.15);
      }

      html[data-theme="light"] .site-bg::after {
        background: rgba(225, 29, 72, 0.12);
      }

      .container {
        width: min(var(--max-width), calc(100% - 2rem));
        margin-inline: auto;
      }

      .section {
        padding: 84px 0;
      }

      .section-title {
        font-size: clamp(1.8rem, 1.2rem + 2vw, 2.7rem);
        margin: 0 0 12px;
      }

      .section-kicker {
        font-family: var(--font-mono);
        color: var(--primary);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-size: 0.78rem;
        margin-bottom: 10px;
      }

      .glass-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-soft);
        backdrop-filter: blur(16px);
        transition: transform 260ms ease, border-color 260ms ease, box-shadow 260ms ease;
        position: relative;
        overflow: hidden;
      }

      .glass-card::before {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        top: 0;
        height: 3px;
        background: var(--gradient-a);
        opacity: 0;
        transform: translateY(-8px);
        transition: opacity 220ms ease, transform 220ms ease;
      }

      .glass-card:hover {
        transform: translateY(-6px);
        border-color: rgba(78, 205, 196, 0.38);
        box-shadow: var(--shadow-glow);
      }

      .glass-card:hover::before {
        opacity: 1;
        transform: translateY(0);
      }

      .reveal {
        opacity: 0;
        transform: translateY(22px);
        transition: opacity 540ms ease, transform 540ms ease;
      }

      .reveal.is-visible {
        opacity: 1;
        transform: translateY(0);
      }

      .divider-label {
        margin: 30px 0 22px;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 12px;
        color: var(--muted);
        font-family: var(--font-mono);
        font-size: 0.78rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .divider-label::before,
      .divider-label::after {
        content: "";
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--border), transparent);
      }

      @keyframes drift {
        to {
          transform: translate3d(30px, -24px, 0);
        }
      }

      @media (max-width: 768px) {
        .section {
          padding: 66px 0;
        }

        .container {
          width: min(var(--max-width), calc(100% - 1.2rem));
        }
      }
    </style>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Aller au contenu principal</a>
    <div class="site-bg" aria-hidden="true"></div>
    <Header navItems={navItems} profile={profile} />
    <main id="main-content">
      <slot />
    </main>
    <Footer navItems={navItems} profile={profile} />
    <BackToTop />
    <AiAssistant />
    <ResumeExport />

    <script>
      // Reveal elements as they enter the viewport for smooth section transitions.
      const revealElements = document.querySelectorAll(".reveal");
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry, index) => {
            if (!entry.isIntersecting) return;
            const target = entry.target;
            const delay = Number(target.getAttribute("data-delay") || 0);
            window.setTimeout(() => target.classList.add("is-visible"), delay + index * 18);
            revealObserver.unobserve(target);
          });
        },
        { threshold: 0.18, rootMargin: "0px 0px -6% 0px" }
      );
      revealElements.forEach((element) => revealObserver.observe(element));
    </script>

    <!-- Vercel Analytics -->
    <script>
      import { inject } from "@vercel/analytics";
      inject();
    </script>
  </body>
</html>
